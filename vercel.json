{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "https://educadq-lms-production.up.railway.app/api/trpc/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://educadq-lms-production.up.railway.app/api/$1"
    },
    {
      "source": "/trpc/(.*)",
      "destination": "https://educadq-lms-production.up.railway.app/api/trpc/$1"
    },
    {
      "source": "/((?!api|trpc|assets|favicon.ico).*)$",
      "destination": "/index.html"
    }
  ]
}
