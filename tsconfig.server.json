{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/server",
    "rootDir": "server",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "server/**/*.ts"
  ],
  "exclude": [
    "server/**/*.test.ts",
    "server/tests",
    "node_modules"
  ]
}
