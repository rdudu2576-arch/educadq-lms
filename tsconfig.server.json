{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/server",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "lib": ["ES2020"]
  },
  "include": [
    "server/**/*",
    "domain/**/*",
    "infra/**/*",
    "routers/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "client/**/*"
  ]
}
